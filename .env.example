# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://leadwise:leadwise@localhost:5432/leadwise

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave empty for local dev

# ─── LLM (platform-level default — overridden per tenant) ────────────────────
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                  # for embeddings (text-embedding-3-small)

# ─── Green API (platform-level test instance) ────────────────────────────────
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ─── Green API tokens per tenant (stored in tenant_channels.token_ref) ───────
# Seed: PASHUTOMAZIA_GREEN_API_TOKEN=<token> python scripts/seed_tenants.py --tenant pashutomazia
PASHUTOMAZIA_GREEN_API_TOKEN=
# Seed: IROKO_GREEN_API_TOKEN=<token> python scripts/seed_tenants.py --tenant iroko
IROKO_GREEN_API_TOKEN=

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://signoz.simpliflow.me:4317
OTEL_SERVICE_NAME=leadwise-sales-agent
OTEL_ENABLED=false                     # set true in production
